# Comma-separated list of GitHub doc repos to ingest
# Add or remove repos as needed — any public percona/* doc repo works
REPOS=percona/psmysql-docs,percona/pxc-docs,percona/pxb-docs,percona/pmm-doc,percona/k8sps-docs,percona/k8spxc-docs,percona/percona-valkey-doc

# Base directory for cloned repos and ChromaDB persistence
# Default: ./data (relative to project root)
DATA_DIR=./data

# Auto-refresh: re-ingest docs if older than N days (on MCP server startup)
# Set to 0 to disable auto-refresh
REFRESH_DAYS=7
